# Supabase (client)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase (server, for Vercel functions)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (AI dream interpretation)
VITE_ANTHROPIC_API_KEY=

# Stripe (payments) — legacy, currently inactive in favor of RevenueCat
VITE_STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# RevenueCat (subscriptions, iOS + Android only)
# Single unified public API key from RevenueCat Dashboard > Project >
# API keys. Works across iOS and Android. "test_" prefix denotes the
# sandbox key; switch to the production key before App Store submission.
VITE_REVENUECAT_API_KEY=

# Server-side shared secret matching the Authorization header configured
# in RevenueCat Dashboard > Project > Integrations > Webhooks. Used to
# authenticate incoming RevenueCat webhook requests.
REVENUECAT_WEBHOOK_AUTH=
